}

rgy() {
    dir=$(find "$HOME" -type d 2>/dev/null | fzf --prompt="Select directory: ")
    [ -z "$dir" ] && return
    result=$(rg --hidden --line-number --no-heading --color=always -F "" "$dir" \
        | fzf --ansi \
              --phony \
              --bind "change:reload:rg --hidden --line-number --no-heading --color=always -F {q} \"$dir\" || true" \
              --delimiter : \
              --preview 'bat --style=numbers --color=always {1} --highlight-line {2}' \
              --preview-window=right:60%)
    [ -z "$result" ] && return
    file=$(echo "$result" | cut -d: -f1)
    parent=$(dirname "$file")
    yazi "$parent"
}


ex() {
    if [ -z "$1" ]; then
        echo "Usage: ex <archive-file>"
        return 1
    fi
    if [ ! -f "$1" ]; then
        echo "File not found: $1"
        return 1
    fi
    case "$1" in
        *.tar)         tar -xvf "$1" ;;
        *.tar.gz|*.tgz) tar -xzvf "$1" ;;
        *.tar.bz2)     tar -xjvf "$1" ;;
        *.tar.xz)      tar -xJvf "$1" ;;
        *.zip)         unzip "$1" ;;
        *.rar)         unrar x "$1" ;;
        *.7z)          7z x "$1" ;;
        *.gz)          gunzip "$1" ;;
        *.bz2)         bunzip2 "$1" ;;
        *) echo "Unsupported archive format." ;;
    esac
}

compress() {
    if [ -z "$1" ] || [ -z "$2" ]; then
        echo "Usage: compress <output-file> <file-or-folder>"
        return 1
    fi
    case "$1" in
        *.tar)         tar -cvf "$1" "$2" ;;
        *.tar.gz|*.tgz) tar -czvf "$1" "$2" ;;
        *.tar.bz2)     tar -cjvf "$1" "$2" ;;
        *.tar.xz)      tar -cJvf "$1" "$2" ;;
        *.zip)         zip -r "$1" "$2" ;;
        *.7z)          7z a "$1" "$2" ;;
        *) echo "Unsupported archive format." ;;
    esac
}


