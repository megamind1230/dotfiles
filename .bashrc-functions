crondo() { # rondo with copy
    while true; do
        cd /mnt/hdd/hcore
        local item

        item=$(find . -maxdepth 1 -type f -printf '%f\n' | shuf -n 1)

        if [[ -z "$item" ]]; then
            echo "No files found in directory"
            return 1
        fi

        echo "$item"
        read -p "Move to Downloads? (y/N/q): " response

        if [[ "$response" =~ ^[Qq]$ ]]; then
            return 0
        elif [[ "$response" =~ ^[Yy]$ ]]; then
            mv -- "$item" "/home/dt/Downloads"
            echo "Moved '$item' to Downloads"
        else
            mv -- "$item" "/mnt/hdd/hcoreExtend"
            echo "Moved '$item' to /mnt/hdd/hcoreExtend"
        fi
        echo "-----------------------"
    done
}


