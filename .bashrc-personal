# fzf in tldr pages
fzft() {
  local cmd
  cmd=$(find ~/.local/share/tldr/pages -type f -name "*.md" | sed 's|.*/||; s|\.md||' | fzf --preview "tldr {1}" --preview-window=right:70%)
  [ -n "$cmd" ] && tldr "$cmd"
}
c() {
    read -p "Enter cht.sh query: " query
    [[ -z "$query" ]] && return 1
    cht.sh $query | sed 's/\x1b\[[0-9;]*m//g' | nvim -
}

