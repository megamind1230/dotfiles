elif [[ "$XDG_SESSION_TYPE" == "x11" ]]; then
    sed '1,/^### DATA ###$/d' $0 | rofi -dmenu | cut -d ' ' -f 1 | tr -d '\n' | xclip -sel clipboard
fi
exit

