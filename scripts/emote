#!/bin/bash
# now i use rofi again
  # updated to fuzzel instead of wofi
    # cat t | fuzzel --dmenu | cut -d ' ' -f1 | tr -d '\n' | wl-copy
# old
  # wtype 0
  # if [ $? -eq 0 ]
  # then
  #     sed '1,/^### DATA ###$/d' $0 | wofi --show dmenu -i | cut -d ' ' -f 1 | tr -d '\n' | wtype -
  # else
  #     sed '1,/^### DATA ###$/d' $0 | wofi --show dmenu -i | cut -d ' ' -f 1 | tr -d '\n' | wl-copy
