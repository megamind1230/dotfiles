#!/usr/bin/env bash

if [[ "$XDG_SESSION_TYPE" == "wayland" ]]; then
    echo "hi wayland"

elif [[ "$XDG_SESSION_TYPE" == "x11" ]]; then
    echo "hi xorg"

# Fallback method (in case XDG_SESSION_TYPE is empty)
elif [[ -n "$WAYLAND_DISPLAY" ]]; then
    echo "hi wayland"

elif [[ -n "$DISPLAY" ]]; then
    echo "hi xorg"

else
    echo "Unknown display server"
fi
